        tuotto = suuri
    flight_counter += 1
    balance = rahat[0] + tuotto - kulut
    print(
        f"\nRahat ennen lentoa: {int(rahat[0])}€ \nTuotto: {int(tuotto)}€ \nKulut yhteensä:-{int(kulut)}€ \nSinulla on nyt {int(balance)}€ rahaa.")
