Muutokset kokonaisuudessa mitä relaatiokantaan ollaan tehty:
- country taulussa on Continent lisätty pääavaimeksi
- goal_reached tauluun on lisätty continent_id, joka on vierasavain mikä viittaa countryn: continent pääavaimeen
- game taulussa id on muutettu auto_incrementiksi
- game taulussa CO2 budjetti ja consumed on vaihdettu balance ja flight nimmisiin
- balance default value on 2000
- flight default value on 0

alter table goal_reached add column continent.id varchar(40) NOT NULL;
alter table goal_reached modify goal_id int(11) null;
alter table game modify column game.id int not null auto_increment;
alter table country add index idx (continent);
alter table airport add constraint fk_iso foreign key (iso_country) references country(iso_country);
alter table goal_reached add constraint fk_continent foreign key (continent_id) references country(continent);
ALTER TABLE game CHANGE co2_consumed balance INT(11) DEFAULT 2000;
ALTER TABLE game CHANGE co2_budget flights INT(3) DEFAULT 0;

CREATE TABLE IF NOT EXISTS highscore (
  id INT AUTO_INCREMENT PRIMARY KEY,
  screen_name VARCHAR(50) NOT NULL,
  final_money INT NOT NULL,
  flights_count INT NOT NULL,
  finished_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;
